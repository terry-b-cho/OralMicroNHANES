# .rds files (but allow results directory)
**/*.rds
!results/**/*.rds

# Data files
**/*.{csv,tsv,xlsx,xls,db,sqlite,sqlite3,zip}
# But allow results directory
!results/**/*.{csv,tsv}

# Output and media files
**/*.{pdf,png,jpg,jpeg,tiff,bmp}
# But allow results directory
!results/**/*.{pdf,png,jpg,jpeg,tiff,bmp}

# Adobe Illustrator files
**/*.{ai}

# Figure editing files - exclude entire directory from GitHub
figure_editing/
figure_editing/**

# HTML files
**/*.{html}

# Log files - all .log files are ignored repository-wide
**/*.log
*.log
# Other stream output files
**/*.{out,err}
# Directories named "logs" - ignore contents but keep directory
**/logs/*
!**/logs/.gitkeep

# IDE specific files
.idea/
.vscode/
**/*.{swp,swo}

# macOS system files
.DS_Store
**/.DS_Store

# R cache and temporary directories
**/*_cache/
**/logs/

# Project specific directories - ignore contents but keep directories
data/*
!data/.gitkeep
logs/*
!logs/.gitkeep

# Results directory - allow structure but exclude large files
# The results directory structure will be preserved on GitHub
# Individual files over 50MB in results are excluded below

# All files underneath /data directory are ignored but the directory itself is kept i.e. All the directories that are underneath this directory should be visible and uploaded. However, the individual files within each of the nested directories should not be transferred. I. blank directories and its subdirectories should be uploaded.
data/*
!data/.gitkeep  # This file ensures the data/ directory 
