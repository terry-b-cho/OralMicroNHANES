# R specific files
.Rproj.user/
.Rhistory
.Ruserdata
.Rapp.history
.RData
# RDS files: Large serialized R objects (can exceed 100MB, e.g., tidied_results.rds files up to 1.6GB)
.rds

# Data files exceeding GitHub's 100MB limit
# SQLite databases: Large database files (2-2.4GB each) containing NHANES oral microbiome data
# Excel files: Large spreadsheet files (e.g., goldData.xlsx ~216MB)
# ZIP archives: Compressed data archives (e.g., goldData.xlsx.zip ~153MB)
**/*.{tsv,xlsx,xls,db,sqlite,sqlite3,zip}

# Output and media files exceeding GitHub's 100MB limit
# AI files: Adobe Illustrator files (can exceed 100MB, e.g., Fig2_main_CLR.ai ~123MB)
# PDF files: Large PDF documents (e.g., Figures 11:17.pdf ~97MB)
# HTML files: Large generated documentation/report files
# Image files: Large raster/vector graphics
**/*.{ai,html,png,jpg,jpeg,tiff,bmp}
**/*.pdf

# Large text and sequence files exceeding GitHub's 100MB limit
# TXT files: Large diversity matrix files (e.g., beta diversity matrices up to 991MB)
# FASTA/GZ files: Large sequence alignment files (e.g., SILVA fasta.gz ~1.2GB)
**/*.fasta.gz
**/*beta*.txt

# Log files
**/*.{log,out,err}

# Temporary files
**/*.{tmp,temp}
*~

# OS specific files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE specific files
.idea/
.vscode/
**/*.{swp,swo}

# R cache and temporary directories
**/*_cache/
**/logs/

